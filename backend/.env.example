# =============================================================================
# FlowLingo Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.

# --- Database ---
# Required. Use Neon Postgres connection string.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/flowlingo?sslmode=require
DATABASE_URL=

# --- Authentication ---
# Required. Generate with: openssl rand -base64 32
# Keep this secret — it signs all JWTs.
JWT_SECRET=

# --- AI Providers ---
# At least one AI provider API key is required for real translation/analysis.
# OpenAI (GPT-4o) is recommended for initial launch — it handles translate, analyze, and embeddings.
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet) — optional, used as failover if OpenAI is unavailable.
ANTHROPIC_API_KEY=

# Google Gemini (1.5 Flash) — optional, used as secondary failover.
GOOGLE_API_KEY=

# --- Caching (Optional) ---
# Redis URL for caching translation results (24h TTL).
# The backend works without this — caching is a performance optimization.
# Example: redis://default:pass@...upstash.io:6379
UPSTASH_REDIS_REST_URL=

# --- Payments & Subscriptions ---
# Find these in Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
# Stripe webhook secret — set this in the Stripe Dashboard webhook configuration
# Point the webhook to: https://your-backend-url.com/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=

# Apple In-App Purchase configuration (JSON format)
APPLE_IAP_CONFIG=

# Google Play Billing configuration (JSON format)
GOOGLE_PLAY_CONFIG=

# --- Server ---
# Port the server listens on (default: 8080)
PORT=8080

# Comma-separated list of allowed CORS origins.
# Include your website URL, mobile app scheme, and localhost for development.
# Example: https://flowlingo.ctonew.app,https://flowlingo.ai,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://flowlingo.ctonew.app,https://flowlingo.ai